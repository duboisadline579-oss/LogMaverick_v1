<Window x:Class="LogMaverick.Views.LogDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Detail" Height="650" Width="850"
        Background="#161616" Foreground="White"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" Padding="10,6" CornerRadius="3" Margin="0,0,0,8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="TxtHeader" Foreground="#888" FontSize="11" FontFamily="Consolas"/><TextBlock x:Name="TxtType" FontSize="12" FontWeight="Bold" Margin="0,3,0,0"/></StackPanel><Button Grid.Column="1" Content="전체복사" Click="Copy_Click" Width="80" Height="28" Background="#252525" Foreground="#CCC" BorderBrush="#444"/></Grid></Border>
        <Grid Grid.Row="1" Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="TxtSearch" Background="#0D0D0D" Foreground="White" BorderBrush="#444" BorderThickness="1" Height="28" VerticalContentAlignment="Center" Padding="8,0" FontSize="11" TextChanged="Search_Changed"/><TextBlock Grid.Column="0" Text="검색..." Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="10,0" IsHitTestVisible="False" x:Name="SearchHint"/><TextBlock Grid.Column="1" x:Name="TxtMatchCount" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="8,0"/></Grid>
        <ListView x:Name="KvList" Grid.Row="2" Background="#0F0F0F" Foreground="#DDDDDD" BorderThickness="0" SelectionMode="Extended">
            <ListView.View><GridView>
                <GridViewColumn Header="Key" Width="220">
                    <GridViewColumn.CellTemplate><DataTemplate>
                        <TextBlock Text="{Binding Key}" Foreground="{Binding KeyColor}" FontWeight="Bold" FontFamily="Consolas" FontSize="12"/>
                    </DataTemplate></GridViewColumn.CellTemplate>
                </GridViewColumn>
                <GridViewColumn Header="Value" Width="540">
                    <GridViewColumn.CellTemplate><DataTemplate>
                        <TextBox Text="{Binding Value, Mode=OneWay}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" IsReadOnly="True" Background="Transparent" BorderThickness="0" MaxHeight="150" VerticalScrollBarVisibility="Auto" PreviewMouseDown="ValueBox_PreviewMouseDown">
                            <TextBox.Style><Style TargetType="TextBox">
                                <Setter Property="Foreground" Value="#DDDDDD"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValueColor}" Value="#FF6B6B"><Setter Property="Foreground" Value="#FF6B6B"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ValueColor}" Value="#00C853"><Setter Property="Foreground" Value="#00C853"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ValueColor}" Value="#FFD700"><Setter Property="Foreground" Value="#FFD700"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ValueColor}" Value="#AADDFF"><Setter Property="Foreground" Value="#AADDFF"/></DataTrigger>
                                </Style.Triggers>
                            </Style></TextBox.Style>
                        </TextBox>
                    </DataTemplate></GridViewColumn.CellTemplate>
                </GridViewColumn>
            </GridView></ListView.View>
        </ListView>
        <TextBlock Grid.Row="3" Text="💡 Value 클릭 후 드래그로 선택 및 Ctrl+C 복사 가능" Foreground="#555" FontSize="10" Margin="0,6,0,0"/>
    </Grid>
</Window>
